        },
        {
          "name": "Get playbook",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/ansible/playbooks/setup-nginx.yml"
          }
        },
        {
          "name": "Create playbook",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/ansible/playbooks",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"setup-nginx.yml\",\n  \"content\": \"---\\n- hosts: all\\n  become: true\\n  tasks:\\n    - name: Install nginx\\n      apt:\\n        name: nginx\\n        state: present\\n\"\n}"
            }
          }
        },
        {
          "name": "Update playbook",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/ansible/playbooks/setup-nginx.yml",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"---\\n- hosts: all\\n  become: true\\n  tasks:\\n    - name: Install nginx\\n      apt:\\n        name: nginx\\n        state: latest\\n\"\n}"
            }
          }
        },
        {
          "name": "Delete playbook",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/ansible/playbooks/setup-nginx.yml"
          }
        },
        {
          "name": "Run status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/ansible/run/status"
          }
        },
        {
          "name": "Cancel run",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/ansible/run"
          }
        },
        {
          "name": "Get run queue",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/ansible/run/queue"
          }
        }
      ]
    },
